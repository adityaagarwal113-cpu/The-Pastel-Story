rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "adityaagarwal113@gmail.com" || 
              request.auth.token.email == "shiwaniag456@gmail.com" ||
              request.auth.uid == "nGaU8BiqU2OJN0SSwGCf3M0roN52");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'address', 'pincode']);

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 100 &&
               (!('createdAt' in data) || data.createdAt == request.time || data.createdAt is timestamp) &&
               (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
               (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
               (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
               (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
               (!('pincode' in data) || (data.pincode is string && data.pincode.size() <= 10));
      }
    }

    // --- Products ---
    match /products/{productId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();

      function isValidProduct(data) {
        return data.keys().hasAll(['id', 'name', 'price', 'category', 'imgs']) &&
               data.id is number &&
               data.name is string && data.name.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               data.category is string && data.category.size() <= 50 &&
               (!('desc' in data) || (data.desc is string && data.desc.size() <= 1000)) &&
               (!('oldPrice' in data) || data.oldPrice == null || (data.oldPrice is number && data.oldPrice >= 0)) &&
               (!('emoji' in data) || (data.emoji is string && data.emoji.size() <= 10)) &&
               (!('sizes' in data) || (data.sizes is list && data.sizes.size() <= 10)) &&
               (!('color' in data) || (data.color is string && data.color.size() <= 50)) &&
               (!('badge' in data) || (data.badge is string && data.badge.size() <= 50)) &&
               (!('oos' in data) || data.oos is bool) &&
               data.imgs is list && data.imgs.size() <= 20;
      }
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      allow update: if isAdmin() && (
        // Action: Update Status or Tracking
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'trackingId', 'trackingLink']) &&
        incoming().status in ['Payment Pending Verification', 'Order Placed', 'Processing', 'Shipped', 'Delivered'] &&
        (!('trackingId' in incoming()) || (incoming().trackingId is string && incoming().trackingId.size() <= 100)) &&
        (!('trackingLink' in incoming()) || (incoming().trackingLink is string && incoming().trackingLink.size() <= 500))
      );
      allow delete: if isAdmin();

      function isValidOrder(data) {
        return data.keys().hasAll(['orderId', 'userId', 'total', 'status', 'timestamp', 'userName', 'userPhone', 'address', 'pincode', 'items']) &&
               isValidId(data.orderId) &&
               data.userId == request.auth.uid &&
               data.total is number && data.total >= 0 &&
               data.status in ['Order Placed', 'Payment Pending Verification'] &&
               data.timestamp == request.time &&
               data.userName is string && data.userName.size() <= 100 &&
               data.userPhone is string && data.userPhone.size() <= 20 &&
               data.address is string && data.address.size() <= 500 &&
               data.pincode is string && data.pincode.size() <= 10 &&
               data.items is string && data.items.size() <= 5000 &&
               (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 100)) &&
               (!('paymentProof' in data) || (data.paymentProof is string && data.paymentProof.size() <= 200)) &&
               (!('trackingId' in data) || (data.trackingId is string && data.trackingId.size() <= 100)) &&
               (!('trackingLink' in data) || (data.trackingLink is string && data.trackingLink.size() <= 500));
      }
    }

    // --- Site Config ---
    match /site_config/{configId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidConfig(incoming());
      allow delete: if isAdmin();

      function isValidConfig(data) {
        return (!('siteName' in data) || (data.siteName is string && data.siteName.size() <= 200)) &&
               (!('heroTitle' in data) || (data.heroTitle is string && data.heroTitle.size() <= 200)) &&
               (!('heroSubtitle' in data) || (data.heroSubtitle is string && data.heroSubtitle.size() <= 500)) &&
               (!('heroImage' in data) || (data.heroImage is string && data.heroImage.size() <= 1000000)) &&
               (!('heroSmallImage' in data) || (data.heroSmallImage is string && data.heroSmallImage.size() <= 1000000)) &&
               (!('heroButtonText' in data) || (data.heroButtonText is string && data.heroButtonText.size() <= 100)) &&
               (!('marqueeText' in data) || (data.marqueeText is string && data.marqueeText.size() <= 1000)) &&
               (!('galleryImages' in data) || (data.galleryImages is list && data.galleryImages.size() <= 50)) &&
               (!('aboutTitle' in data) || (data.aboutTitle is string && data.aboutTitle.size() <= 500)) &&
               (!('aboutVision' in data) || (data.aboutVision is string && data.aboutVision.size() <= 2000)) &&
               (!('aboutSecondary' in data) || (data.aboutSecondary is string && data.aboutSecondary.size() <= 2000)) &&
               (!('aboutImage' in data) || (data.aboutImage is string && data.aboutImage.size() <= 1000000)) &&
               (!('contactWhatsApp' in data) || (data.contactWhatsApp is string && data.contactWhatsApp.size() <= 50)) &&
               (!('contactEmail' in data) || (data.contactEmail is string && data.contactEmail.size() <= 100)) &&
               (!('instagramUrl' in data) || (data.instagramUrl is string && data.instagramUrl.size() <= 500)) &&
               (!('quoteText' in data) || (data.quoteText is string && data.quoteText.size() <= 1000)) &&
               (!('quoteAuthor' in data) || (data.quoteAuthor is string && data.quoteAuthor.size() <= 200)) &&
               (!('categories' in data) || (data.categories is list && data.categories.size() <= 50));
      }
    }

    // --- Carts & Wishlists ---
    match /carts/{userId} {
      allow get, write: if isOwner(userId);
    }
    match /wishlists/{userId} {
      allow get, write: if isOwner(userId);
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if (resource == null) || (resource.data.status == 'approved') || isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && 
                      incoming().status == 'approved' && 
                      isValidReview(incoming());
      allow update: if isAdmin() && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'comment'])
                    );
      allow delete: if isAdmin();

      function isValidReview(data) {
        return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'status', 'timestamp']) &&
               data.productId is number &&
               data.userId == request.auth.uid &&
               data.userName is string && data.userName.size() <= 100 &&
               data.rating is number && data.rating >= 1 && data.rating <= 5 &&
               data.comment is string && data.comment.size() <= 1000 &&
               data.status in ['approved'] &&
               data.timestamp == request.time;
      }
    }
  }
}
